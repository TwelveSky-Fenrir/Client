  <PropertyGroup Label="UserMacros" />
  <PropertyGroup>
    <!-- Sortie de l'exe DIRECTEMENT dans GameData (racine des dossiers du jeu
         G01_GFONT/G02_GINFO/G03_GDATA/...) : le .exe se trouve a la racine et resout les
         chemins relatifs du jeu sans configuration (cwd = son propre dossier, cf.
         ResolveGameDataDir candidat "."). Les intermediaires (.obj/.pdb de compil) restent
         ranges sous build\int\ pour ne PAS polluer GameData. Debug et Release ecrivent le
         meme GameData\TwelveSky2.exe (on lance une config a la fois). -->
    <OutDir>$(ProjectDir)GameData\</OutDir>
    <IntDir>$(SolutionDir)build\int\$(ProjectName)\$(Platform)\$(Configuration)\</IntDir>
    <!-- DirectX SDK (June 2010) : fournit d3dx9 (sprite/police/effet/texture). -->
    <DXSDK>$(DXSDK_DIR)</DXSDK>
    <DXSDK Condition="'$(DXSDK)' == ''">C:\Program Files (x86)\Microsoft DirectX SDK (June 2010)\</DXSDK>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level3</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <PreprocessorDefinitions>_CRT_SECURE_NO_WARNINGS;_WINSOCK_DEPRECATED_NO_WARNINGS;WIN32_LEAN_AND_MEAN;NOMINMAX;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- src d'abord ; DXSDK Include ensuite (fournit d3dx9.h ; d3d9.h y est aussi, cohérent).
           external\oggvorbis\include : ogg/vorbis/vorbisfile (Audio/OggVorbisDecoder).
           external\SilverLining\Include : headers SDK (utilises seulement si
           TS2_SILVERLINING_ENGINE_AVAILABLE=1 ; inoffensif sinon). -->
      <AdditionalIncludeDirectories>$(ProjectDir)src;$(ProjectDir)external\oggvorbis\include;$(ProjectDir)external\SilverLining\Include;$(DXSDK)Include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- /FS : ecriture PDB synchronisee (evite C1041 quand le toolset compile en parallele). -->
      <AdditionalOptions>/FS %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <!-- ole32.lib : Co* (CoInitializeEx/CoCreateInstance/CoUninitialize) ; strmiids.lib :
           GUID DirectShow (CLSID_FilterGraph, IID_IGraphBuilder/IMediaControl/IVideoWindow/
           IMediaEventEx), requis par App::Run() (lecture bloquante INTRO.AVI, fidele WinMain 0x4609C0). -->
      <!-- vorbisfile/vorbis/ogg statiques (Audio/OggVorbisDecoder) : libs prebuild /MT
           (LIBCMT) -> le projet est bascule en /MT (cf. RuntimeLibrary ci-dessous).
           legacy_stdio_definitions.lib : les libs ogg (compilees avant VS2015) referencent
           _sprintf, symbole jadis exporte mais desormais inline dans l'UCRT ; cette lib
           fournit ces definitions heritees (corrige LNK2001 _sprintf). -->
      <AdditionalDependencies>user32.lib;gdi32.lib;winmm.lib;ole32.lib;strmiids.lib;vorbisfile_static.lib;vorbis_static.lib;ogg_static.lib;legacy_stdio_definitions.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(DXSDK)Lib\x86;$(ProjectDir)external\oggvorbis\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <!-- _DEBUG retire + /MT (au lieu de /MDd) : les libs ogg prebuild sont /MT (LIBCMT,
           CRT statique release) ; le projet doit matcher. _DEBUG n'est reference nulle part
           dans src/ -> aucun impact comportemental. Debug = non optimise + PDB, CRT statique. -->
      <PreprocessorDefinitions>WIN32;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
    </ClCompile>
    <Link>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>WIN32;NDEBUG;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- /MT (au lieu de /MD) : match des libs ogg prebuild /MT (LIBCMT). Exe autonome. -->
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
    </ClCompile>
    <Link>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>
